            "console": "integratedTerminal",
            "args": ["--help"],
        },
        {
            "name": "Python Debugger: mailevbills --help",
            "type": "debugpy",
            "request": "launch",
            "program": "src/evbilling/mailevbills.py",
            "console": "integratedTerminal",
            "args": ["--help"],
        },
        {
            "name": "Python Debugger: evbilling --version",
            "type": "debugpy",
            "request": "launch",
            "program": "src/evbilling/evbilling.py",
            "console": "integratedTerminal",
            "args": ["--version"],
        },
        {
            "name": "Python Debugger: evtariffs --version",
            "type": "debugpy",
            "request": "launch",
            "program": "src/evbilling/evtariffs.py",
